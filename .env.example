# Obrigatório para `npm run dev` e `npm run build`.
# Apenas dígitos: código do país + DDD + número (ex.: 5511987654321).
# Railway: defina em Variables antes do deploy (Vite lê no build).
VITE_WHATSAPP_NUMBER=5511987654321

# Opcional: contador “pessoas online” na LP (Supabase Realtime Presence).
# Projeto gratuito: https://supabase.com — Settings → API (URL + anon public).
# Garanta Realtime ativo no projeto (costuma vir ligado por padrão).
# Railway: inclua as duas variáveis no mesmo serviço e faça redeploy.
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=